<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OLWforWordPress.ViewModels"
        x:Class="OLWforWordPress.Views.SetupWizardWindow"
        x:DataType="vm:SetupWizardViewModel"
        Title="OLW for WordPress"
        Width="460" Height="440"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#f7f7f8">

    <Border Padding="40,32" Background="White" CornerRadius="0"
            Margin="0">
        <StackPanel Spacing="14" VerticalAlignment="Center">

            <StackPanel Spacing="4" HorizontalAlignment="Center" Margin="0,0,0,12">
                <TextBlock Text="OLW for WordPress"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="連線至您的 WordPress 網站"
                           FontSize="13" Foreground="#888"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="網站網址" FontSize="12" FontWeight="Medium" Foreground="#555" />
                <TextBox Text="{Binding SiteUrl}"
                         Watermark="https://example.com"
                         IsEnabled="{Binding !IsConnecting}"
                         CornerRadius="6" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="使用者名稱" FontSize="12" FontWeight="Medium" Foreground="#555" />
                <TextBox Text="{Binding Username}"
                         Watermark="admin"
                         IsEnabled="{Binding !IsConnecting}"
                         CornerRadius="6" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="應用程式密碼" FontSize="12" FontWeight="Medium" Foreground="#555" />
                <TextBox Text="{Binding AppPassword}"
                         PasswordChar="●"
                         Watermark="xxxx xxxx xxxx xxxx"
                         IsEnabled="{Binding !IsConnecting}"
                         CornerRadius="6" />
            </StackPanel>

            <Button Content="連線"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Click="OnConnectClick"
                    IsEnabled="{Binding !IsConnecting}"
                    Height="38"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#0066CC"
                    Foreground="White"
                    CornerRadius="8"
                    Margin="0,6,0,0" />

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#CC4444"
                       FontSize="12"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        </StackPanel>
    </Border>
</Window>
