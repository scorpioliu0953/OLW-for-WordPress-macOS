<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OLWforWordPress.ViewModels"
        xmlns:ctrl="using:OLWforWordPress.Controls"
        x:Class="OLWforWordPress.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding BlogName, StringFormat='OLW for WordPress - {0}'}"
        Width="1100" Height="780"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#f7f7f8">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="White" Padding="12,8" BorderBrush="#e4e4e7" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Content="+ 新增文章" Click="OnNewPostClick" Classes="action-btn" />
                    <Button Content="發布 / 更新" Click="OnPublishClick" Classes="publish-btn" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="狀態" VerticalAlignment="Center" Foreground="#666" FontSize="13" />
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Width="110" FontSize="13" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="*,270" Margin="0">

            <!-- Editor Area -->
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*,Auto" Margin="16,12,8,12">

                <!-- Title -->
                <TextBox Grid.Row="0"
                         Text="{Binding Title}"
                         Watermark="文章標題"
                         Classes="title-input"
                         Margin="0,0,0,12" />

                <!-- Formatting Toolbar -->
                <Border Grid.Row="1" Background="White" Padding="4,3" CornerRadius="8"
                        BorderBrush="#e4e4e7" BorderThickness="1" Margin="0,0,0,8"
                        BoxShadow="0 1 3 0 #10000000">
                    <WrapPanel Orientation="Horizontal">
                        <!-- Text formatting -->
                        <Button Content="B" FontWeight="Bold" Click="OnBoldClick"
                                Classes="toolbar-btn" ToolTip.Tip="粗體" />
                        <Button Content="I" FontStyle="Italic" Click="OnItalicClick"
                                Classes="toolbar-btn" ToolTip.Tip="斜體" />
                        <Button Content="U" Click="OnUnderlineClick"
                                Classes="toolbar-btn" ToolTip.Tip="底線" />
                        <Button Content="S" Click="OnStrikeClick"
                                Classes="toolbar-btn" ToolTip.Tip="刪除線" />

                        <Border Width="1" Background="#e0e0e0" Margin="3,6" />

                        <!-- Headings -->
                        <Button Content="H2" Click="OnH2Click"
                                Classes="toolbar-btn" FontWeight="Bold" ToolTip.Tip="標題二" />
                        <Button Content="H3" Click="OnH3Click"
                                Classes="toolbar-btn" FontWeight="Bold" ToolTip.Tip="標題三" />
                        <Button Content="H4" Click="OnH4Click"
                                Classes="toolbar-btn" FontWeight="Bold" ToolTip.Tip="標題四" />

                        <Border Width="1" Background="#e0e0e0" Margin="3,6" />

                        <!-- Lists -->
                        <Button Content="• List" Click="OnUlClick"
                                Classes="toolbar-btn" ToolTip.Tip="無序列表" />
                        <Button Content="1. List" Click="OnOlClick"
                                Classes="toolbar-btn" ToolTip.Tip="有序列表" />
                        <Button Content="❝" Click="OnBlockquoteClick"
                                Classes="toolbar-btn" ToolTip.Tip="引用" />

                        <Border Width="1" Background="#e0e0e0" Margin="3,6" />

                        <!-- Font size -->
                        <ComboBox x:Name="FontSizeCombo" Width="70" Height="28" FontSize="12"
                                  SelectedIndex="0" SelectionChanged="OnFontSizeChanged"
                                  ToolTip.Tip="字體大小">
                            <ComboBoxItem Content="大小" />
                            <ComboBoxItem Content="12px" Tag="12" />
                            <ComboBoxItem Content="14px" Tag="14" />
                            <ComboBoxItem Content="16px" Tag="16" />
                            <ComboBoxItem Content="18px" Tag="18" />
                            <ComboBoxItem Content="20px" Tag="20" />
                            <ComboBoxItem Content="24px" Tag="24" />
                            <ComboBoxItem Content="28px" Tag="28" />
                            <ComboBoxItem Content="32px" Tag="32" />
                        </ComboBox>

                        <!-- Text color -->
                        <ComboBox x:Name="TextColorCombo" Width="62" Height="28" FontSize="12"
                                  SelectedIndex="0" SelectionChanged="OnTextColorChanged"
                                  ToolTip.Tip="文字顏色">
                            <ComboBoxItem Content="文字色" />
                            <ComboBoxItem Content="🔴" Tag="#e53935" />
                            <ComboBoxItem Content="🟠" Tag="#fb8c00" />
                            <ComboBoxItem Content="🟡" Tag="#fdd835" />
                            <ComboBoxItem Content="🟢" Tag="#43a047" />
                            <ComboBoxItem Content="🔵" Tag="#1e88e5" />
                            <ComboBoxItem Content="🟣" Tag="#8e24aa" />
                            <ComboBoxItem Content="⚫" Tag="#333333" />
                            <ComboBoxItem Content="⚪" Tag="#ffffff" />
                        </ComboBox>

                        <!-- Background color -->
                        <ComboBox x:Name="BgColorCombo" Width="62" Height="28" FontSize="12"
                                  SelectedIndex="0" SelectionChanged="OnBgColorChanged"
                                  ToolTip.Tip="背景顏色">
                            <ComboBoxItem Content="背景色" />
                            <ComboBoxItem Content="🟥" Tag="#ffcdd2" />
                            <ComboBoxItem Content="🟧" Tag="#ffe0b2" />
                            <ComboBoxItem Content="🟨" Tag="#fff9c4" />
                            <ComboBoxItem Content="🟩" Tag="#c8e6c9" />
                            <ComboBoxItem Content="🟦" Tag="#bbdefb" />
                            <ComboBoxItem Content="🟪" Tag="#e1bee7" />
                            <ComboBoxItem Content="⬜" Tag="#f5f5f5" />
                        </ComboBox>

                        <Border Width="1" Background="#e0e0e0" Margin="3,6" />

                        <!-- Insert -->
                        <Button Content="🔗" Click="OnLinkClick"
                                Classes="toolbar-btn" ToolTip.Tip="插入連結" />
                        <Button Content="🖼" Click="OnInsertImageClick"
                                Classes="toolbar-btn" ToolTip.Tip="插入圖片（可多選）" />
                        <Button Content="─" Click="OnHrClick"
                                Classes="toolbar-btn" ToolTip.Tip="水平線" />
                        <Button Content="&lt;code&gt;" Click="OnCodeClick" FontSize="11"
                                Classes="toolbar-btn" ToolTip.Tip="行內程式碼" />

                        <Border Width="1" Background="#e0e0e0" Margin="3,6" />

                        <Button Content="── More ──" Click="OnReadMoreClick"
                                Classes="toolbar-btn" FontSize="11" Foreground="#888"
                                ToolTip.Tip="插入繼續閱讀標記" />
                    </WrapPanel>
                </Border>

                <!-- Tab: Visual Edit / HTML Source -->
                <TabControl Grid.Row="2" x:Name="EditorTabs" SelectionChanged="OnEditorTabChanged">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Padding" Value="12,6" />
                        </Style>
                    </TabControl.Styles>

                    <!-- Visual Edit Tab (WYSIWYG block editor) -->
                    <TabItem Header="編輯">
                        <Border Background="White" CornerRadius="0,0,8,8"
                                BorderBrush="#e4e4e7" BorderThickness="1,0,1,1">
                            <ctrl:BlockEditor x:Name="VisualEditor" />
                        </Border>
                    </TabItem>

                    <!-- HTML Source Tab -->
                    <TabItem Header="HTML 原始碼">
                        <Border x:Name="HtmlDropZone"
                                Background="White" CornerRadius="0,0,8,8"
                                BorderBrush="#e4e4e7" BorderThickness="1,0,1,1"
                                DragDrop.AllowDrop="True">
                            <Grid RowDefinitions="*,Auto">
                                <TextBox Grid.Row="0"
                                         x:Name="ContentEditor"
                                         Text="{Binding HtmlContent}"
                                         Watermark="在此輸入文章內容（支援 HTML）..."
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         TextWrapping="Wrap"
                                         Classes="editor-input"
                                         BorderThickness="0" />

                                <Border Grid.Row="1" Padding="10,6" Background="#fafafa"
                                        BorderBrush="#f0f0f0" BorderThickness="0,1,0,0"
                                        CornerRadius="0,0,8,8">
                                    <TextBlock Text="拖曳圖片至此插入，發布時自動上傳"
                                               FontSize="11" Foreground="#aaa"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>

                <!-- Excerpt -->
                <Expander Grid.Row="3" Header="摘要" Margin="0,10,0,0">
                    <Border Background="White" CornerRadius="6" Padding="2">
                        <TextBox Text="{Binding Excerpt}"
                                 Watermark="文章摘要（選填）"
                                 AcceptsReturn="True"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 BorderThickness="0" />
                    </Border>
                </Expander>
            </Grid>

            <!-- Right Sidebar -->
            <Border Grid.Column="1" Background="White" BorderBrush="#e4e4e7"
                    BorderThickness="1,0,0,0" Padding="14,12">
                <ScrollViewer>
                    <StackPanel Spacing="20">

                        <!-- Categories -->
                        <StackPanel Spacing="0">
                            <TextBlock Text="分類" Classes="sidebar-title" />
                            <Border Background="#fafafa" CornerRadius="6" Padding="8,4"
                                    BorderBrush="#f0f0f0" BorderThickness="1">
                                <ScrollViewer MaxHeight="150">
                                    <ItemsControl ItemsSource="{Binding Categories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:CategoryItem">
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected}"
                                                          FontSize="13" Padding="4,2" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <!-- Tags -->
                        <StackPanel Spacing="0">
                            <TextBlock Text="標籤" Classes="sidebar-title" />
                            <TextBox Text="{Binding TagsText}"
                                     Watermark="以逗號分隔，例：旅遊, 美食"
                                     TextWrapping="Wrap"
                                     FontSize="13"
                                     CornerRadius="6" />
                        </StackPanel>

                        <!-- Recent Posts -->
                        <StackPanel Spacing="0">
                            <TextBlock Text="最近文章" Classes="sidebar-title" />
                            <Border Background="#fafafa" CornerRadius="6"
                                    BorderBrush="#f0f0f0" BorderThickness="1">
                                <ListBox ItemsSource="{Binding RecentPosts}"
                                         SelectionChanged="OnRecentPostSelected"
                                         MaxHeight="280"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BlogPostListItem">
                                            <StackPanel Spacing="2" Margin="4,4">
                                                <TextBlock Text="{Binding DisplayTitle}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="13" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Background="#e8f0fe" CornerRadius="3" Padding="5,1">
                                                        <TextBlock Text="{Binding Status}"
                                                                   FontSize="10" Foreground="#1a73e8" />
                                                    </Border>
                                                    <TextBlock Text="{Binding DateDisplay}"
                                                               FontSize="11" Foreground="#999" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>

                        <!-- Delete Button -->
                        <Button Content="刪除此文章"
                                Click="OnDeletePostClick"
                                IsVisible="{Binding IsEditing}"
                                Classes="danger-btn"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="White" Padding="14,6" BorderBrush="#e4e4e7" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#666" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="4" Padding="8,2" Margin="8,0"
                        IsVisible="{Binding PendingImageCount}" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="#E65100">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="📎 {0} 張圖片待上傳">
                                <Binding Path="PendingImageCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Border>
                <ProgressBar Grid.Column="2"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsBusy}"
                             Width="120" Height="3" />
            </Grid>
        </Border>
    </Grid>
</Window>
